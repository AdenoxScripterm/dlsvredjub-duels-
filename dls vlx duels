                end
            end
        end
    end
end)

local function KnifeKill(target)
    game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("KnifeKill"):FireServer(target)
end

-- AUTO KNIFE KILL
task.spawn(function()
    while true do
        RunService.Heartbeat:Wait()

        if autoKnifeKill then
            for _, enemy in pairs(getEnemyPlayers()) do
                if enemy and enemy.Character then
                    local hum = enemy.Character:FindFirstChild("Humanoid")
                    if hum then
                        for i = 1, KnifeKillBurstAmount do
                            KnifeKill(enemy)
                        end
                    end
                end
            end
        end
    end
end)

