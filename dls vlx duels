                    highlight.Name = "GoldenHighlight"
                    highlight.FillColor = HighlightColor
                    highlight.Parent = char
                end
                highlight.Enabled = true
            else
                if highlight then
                    highlight.Enabled = false
                end
            end

            -- HITBOX
            if IsHitboxActive and isEnemy then
                local root = char:FindFirstChild("HumanoidRootPart")
                if root then
                    root.Size = Vector3.new(CurrentHitboxSize, CurrentHitboxSize, CurrentHitboxSize)
                    root.Transparency = CurrentHitboxTransparency
                    root.BrickColor = BrickColor.new("Really black")
                    root.Material = Enum.Material.Neon
                    root.CanCollide = false
                end
            end
