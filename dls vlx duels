-- TEAM DETECT
local function getTeamFrames()
local pg = LocalPlayer:FindFirstChildOfClass("PlayerGui")
if not pg then return end

local main = pg:FindFirstChild("Main")
local mgf = main and main:FindFirstChild("MainGameFrame")
local pf = mgf and mgf:FindFirstChild("PlayersFrame")

if not pf then return end
return pf:FindFirstChild("TeamRedFrame"), pf:FindFirstChild("TeamBlueFrame")

end

local function getFramePlayerNames(frame)
if not frame then return {} end
local names = {}

for _, child in pairs(frame:GetChildren()) do
if child:IsA("Frame") then
table.insert(names, child.Name)
end
end

return names

end

local function getEnemyPlayers()
local red, blue = getTeamFrames()
if not red or not blue then return {} end

local lpName = LocalPlayer.Name:gsub("%s+", "")
local redNames = getFramePlayerNames(red)
local blueNames = getFramePlayerNames(blue)

local inRed = table.find(redNames, lpName) ~= nil
local enemyFrame = inRed and blue or red

local enemies = {}
for _, name in pairs(getFramePlayerNames(enemyFrame)) do
local p = Players:FindFirstChild(name)
if p and p ~= LocalPlayer then
table.insert(enemies, p)
end
end

return enemies

end

-- SILENT AIM
local function getBestSilentTarget()
local target = nil
local shortestDistance = math.huge

for _, v in pairs(Players:GetPlayers()) do
if v ~= LocalPlayer and v.Character then
local head = v.Character:FindFirstChild("Head")
local hum = v.Character:FindFirstChild("Humanoid")

if head and hum and hum.Health > 0 then
local isEnemy = (v.Team ~= LocalPlayer.Team or v.Team == nil)

if isEnemy then      
        local pos = Camera:WorldToViewportPoint(head.Position)      
        local distance = (Vector2.new(pos.X, pos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude      

        if distance < shortestDistance then      
            shortestDistance = distance      
            target = head      
        end      
    end      
end

end

end

return target

end

-- HOOK
local mt = getrawmetatable(game)
local oldIndex = mt.__index
setreadonly(mt, false)

mt.__index = newcclosure(function(self, index)
if _G.SilentAim and self == Mouse and (index == "Hit" or index == "Target") then
local target = getBestSilentTarget()
if target then
return index == "Hit" and target.CFrame or target
end
end
return oldIndex(self, index)
end)

setreadonly(mt, true)

-- AIM (VISIBLE)
local function getClosestVisibleEnemy()
local enemies = getEnemyPlayers()
if #enemies == 0 then return nil end

local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
if not hrp then return nil end

local closest = nil
local minDist = math.huge

for _, p in pairs(enemies) do
local ch = p.Character
local hum = ch and ch:FindFirstChild("Humanoid")
local root = ch and ch:FindFirstChild("HumanoidRootPart")

if hum and hum.Health > 0 and root then
local dist = (hrp.Position - root.Position).Magnitude

if dist < minDist then      
    local params = RaycastParams.new()      
    params.FilterDescendantsInstances = {LocalPlayer.Character}      
    params.FilterType = Enum.RaycastFilterType.Blacklist      

    local result = Workspace:Raycast(hrp.Position, root.Position - hrp.Position, params)      

    if not result or result.Instance:IsDescendantOf(ch) then      
        minDist = dist      
        closest = p      
    end      
end

end

end

return closest

end

-- DISPARO
local function tryShoot(target)
if not target or not currentTool then return end

local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
if not hrp then return end

local targetHrp = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
if not targetHrp then return end

local pos = targetHrp.Position

pcall(function() currentTool.fire:FireServer() end)
pcall(function() currentTool.kill:FireServer(target, (pos - hrp.Position).Unit, hrp.Position) end)

local beam = ReplicatedStorage:FindFirstChild("LocalBeam")
if beam then
beam:Fire(currentTool.Handle or currentTool, pos)
end

end

-- TOOL DETECT
RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    currentTool = nil

    if char then
        for _, t in pairs(char:GetChildren()) do
            if t:IsA("Tool") and t:FindFirstChild("fire") then
                currentTool = t
                break
            end
        end
    end
end)

-- AUTO EQUIP TOOL
RunService.Heartbeat:Connect(function()
    if autoShootKill and autoEquipTool then
        local char = LocalPlayer.Character
        local backpack = LocalPlayer:FindFirstChild("Backpack")

        if char and backpack then
            if not currentTool then
                for _, tool in pairs(backpack:GetChildren()) do
                    if tool:IsA("Tool") and tool:FindFirstChild("fire") then
                        tool.Parent = char
                        break
                    end
                end
            end
        end
    end
end)

-- AUTO SHOOT
RunService.Heartbeat:Connect(function()
    if autoShoot and currentTool then
        local enemy = getClosestVisibleEnemy()
        if enemy then
            tryShoot(enemy)
        end
    end
end)

-- AUTO SHOOT KILL (ATRAVIESA)
RunService.Heartbeat:Connect(function()
    if autoShootKill and currentTool then
        for _, enemy in pairs(getEnemyPlayers()) do
            if enemy and enemy.Character then
                local hum = enemy.Character:FindFirstChild("Humanoid")
